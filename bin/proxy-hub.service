[Unit]
Description=Proxy Hub Service
After=network.target

[Service]
Type=forking
User=root
Group=root
WorkingDirectory=/opt/proxy-hub
PIDFile=/opt/proxy-hub/run/proxy-hub.pid
Environment=JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC -XX:+HeapDumpOnOutOfMemoryError
ExecStart=/opt/proxy-hub/bin/start.sh
ExecStop=/opt/proxy-hub/bin/stop.sh
ExecReload=/opt/proxy-hub/bin/restart.sh
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
